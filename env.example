# Copie para .env e preencha. NUNCA commitar .env.
# Provider: Groq (LLM gratuito e ultra-rápido)
# Embeddings: sentence-transformers local (sem custo, sem API key)

# Groq API Key — crie grátis em https://console.groq.com
GROQ_API_KEY=gsk_substitua_aqui

# Modelos Groq
LLM_MODEL=llama-3.1-8b-instant
CHEAP_MODEL=llama-3.1-8b-instant
PREMIUM_MODEL=llama-3.3-70b-versatile

# Embeddings locais (sentence-transformers, sem custo)
EMBED_MODEL=all-MiniLM-L6-v2

# Opcional — observabilidade (descomente se for usar Langfuse)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
